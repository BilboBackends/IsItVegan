# Copy this file to `.env` and fill in your real key.
# `.env` is gitignored — never commit real keys.
# This file (.env.example) IS tracked — keep only placeholders here.

GOOGLE_PLACES_API_KEY=your-key-here

# Anthropic API key (Claude). Used for menu-link navigation (Haiku) and,
# later, dish classification. Server-side only — never expose client-side.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Menu classifier provider chain. "auto" = claude then codex — SUBSCRIPTIONS
# ONLY (Claude Code login, then Codex/ChatGPT login); the metered Anthropic
# API never runs unless explicitly selected. A provider that hits its usage
# limit mid-run goes into a ~20 min cooldown and the next in the chain takes
# over. Also accepts a single provider or a custom comma-separated priority
# list (e.g. "codex,claude,anthropic" — including anthropic in a chain is the
# opt-in for API billing as a last resort).
CLASSIFIER_PROVIDER=auto
# Model per provider. Sonnet is the smallest model that holds up on the
# nuanced vegan-adaptable judgments, so both Claude paths pin it. Leave
# CODEX_CLASSIFIER_MODEL empty for that CLI's default.
ANTHROPIC_CLASSIFIER_MODEL=claude-sonnet-5
CLAUDE_CLASSIFIER_MODEL=sonnet
CLAUDE_CLASSIFIER_TIMEOUT_SECONDS=900
CODEX_CLASSIFIER_MODEL=
CODEX_CLASSIFIER_TIMEOUT_SECONDS=900
# Explicit path to the codex CLI. Usually unnecessary: PATH is checked first,
# then the copy bundled inside the ChatGPT VS Code extension is found
# automatically.
CODEX_CLI_PATH=

# DeepSeek: the cheap metered tier for bulk classification (~10x below
# Sonnet's price). Like the Anthropic API it ONLY runs when explicitly
# selected (CLASSIFIER_PROVIDER=deepseek or in a custom chain). Its output is
# screened by guardrails.py and audited by audit_spotcheck.py — see CLAUDE.md.
DEEPSEEK_API_KEY=
# "deepseek-chat" and "deepseek-reasoner" are rolling aliases — DeepSeek
# points them at the newest model version automatically.
DEEPSEEK_CLASSIFIER_MODEL=deepseek-chat
DEEPSEEK_CLASSIFIER_TIMEOUT_SECONDS=900
# 0/false = store DeepSeek's raw verdicts, skipping the guardrail screen.
# Spot-check audits still work. Default on.
DEEPSEEK_GUARDRAILS=1
# Per-response output cap. deepseek-chat's API maximum is 8192; raise this
# only if you switch to a model that allows more (e.g. deepseek-reasoner).
DEEPSEEK_MAX_OUTPUT_TOKENS=64000
# Search center + radius for restaurant discovery (Maitland, FL MVP).
# Defaults below cover Maitland; override to test other areas later.
DISCOVERY_LAT=28.6278
DISCOVERY_LNG=-81.3631
DISCOVERY_RADIUS_METERS=4000

# Keep only results whose address is in this city (the area search overshoots
# small towns into neighbors). Leave empty to keep everything. MVP: Maitland.
DISCOVERY_CITY=Maitland

# Grid cell radius for discovery. Nearby Search returns max 20 results per
# call, so the area is tiled with overlapping circles of this radius and
# deduped. Smaller = more thorough but more API calls. 1500m ≈ 49 calls/run.
DISCOVERY_CELL_RADIUS_METERS=1500

# Path to the SQLite database file.
DATABASE_PATH=veganfind.db
